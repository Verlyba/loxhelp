// Prisma schema for the Classroom app.
//
// Target now: SQLite (zero-setup, runs locally on the school PC).
// Swappable later: change `datasource.provider` to "postgresql" / "mysql" and
// the DATABASE_URL to the school server's connection string, then re-run
// `prisma migrate`. Models are kept portable — note SQLite has no native enums,
// so `role` / `themeStyle` are strings validated in app code (see src/lib/roles).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String   @default("STUDENT") // ADMIN | TEACHER | STUDENT
  classId      String? // students belong to a class (2EB, …)
  class        Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions          Session[]
  enrollments       Enrollment[]
  studyGroupMembers StudyGroupMember[]
  pairMembers       PairMember[]
  uploads           Submission[]       @relation("Uploader")
  unitSubmissions   Submission[]       @relation("IndividualUnit")
  grades            Grade[]
  announcements     Announcement[]
  auditLogs         AuditLog[]         @relation("AuditActor")
  consents          AssignmentConsent[]
  testAttempts      TestAttempt[]
  taughtSubjects    Subject[]          @relation("SubjectTeacher")
  sentNotifications ClassNotification[] @relation("NotificationAuthor")
}

// Audit trail for classification/submission-state changes (PRD §5C). Every
// grade write, lock/unlock, deadline extension or delete leaves a row here so
// the teacher has a defensible record of who changed what and when.
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  actor      User     @relation("AuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  action     String // GRADE_SET | GRADE_CHANGE | GRADE_DELETE | SUBMISSION_LOCK | SUBMISSION_UNLOCK | EXTENSION_SET | EXTENSION_CLEAR
  entityType String // "Grade" | "Submission" | …
  entityId   String // e.g. `${assignmentId}:${userId}`
  targetName String   @default("") // human label, e.g. student/pair name for quick reading
  oldValue   String? // previous value (grade/state), null if none
  newValue   String? // new value, null on delete
  meta       String? // optional JSON context
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
}

// Digital consent evidence (PRD §5B). When an assignment requires it, the
// student confirms they were briefed on terms/criteria and (optionally) chose a
// variant. Timestamped + user-bound so it stands as proof in later disputes.
model AssignmentConsent {
  id            String     @id @default(uuid())
  assignmentId  String
  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  acceptedText  String // the exact text the student agreed to (frozen for evidence)
  variant       String? // chosen option/variant, if the task offered a choice
  acceptedAt    DateTime   @default(now())

  @@unique([assignmentId, userId])
  @@index([assignmentId])
}

// Course announcements (Moodle "News forum") — teacher posts, students read.
model Announcement {
  id        String   @id @default(uuid())
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title     String
  body      String   @default("")
  createdAt DateTime @default(now())

  @@index([subjectId])
}

// DB-backed sessions: the cookie holds an opaque token that maps to a row here.
model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Class {
  id            String              @id @default(uuid())
  name          String // e.g. "2EB"
  schoolYear    String // e.g. "2026/2027"
  isArchived    Boolean             @default(false)
  createdAt     DateTime            @default(now())
  subjects      Subject[]
  students      User[]
  notifications ClassNotification[]
}

model Subject {
  id          String  @id @default(uuid())
  name        String // e.g. "Loxone Automation"
  slug        String  @unique // URL: /subjects/loxone
  description String  @default("")
  themeStyle  String  @default("default") // loxone | cad3d | default
  classId     String
  class      Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherId   String?
  teacher     User?   @relation("SubjectTeacher", fields: [teacherId], references: [id], onDelete: SetNull)

  assignments   Assignment[]
  enrollments   Enrollment[]
  pages         SubjectPage[]
  studyGroups   StudyGroup[]
  announcements Announcement[]
  tests         Test[]

  @@index([classId])
  @@index([teacherId])
}

// Teaching group inside a subject — the class splits into these for lessons
// (Loxone → L1, L2, L3; CAD → S1, S2). Pairs live inside a study group.
model StudyGroup {
  id        String  @id @default(uuid())
  name      String // "L1", "S2", …
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  members     StudyGroupMember[]
  pairs       Pair[]
  submissions Submission[]

  @@unique([subjectId, name])
  @@index([subjectId])
}

model StudyGroupMember {
  id           String     @id @default(uuid())
  studyGroupId String
  userId       String
  studyGroup   StudyGroup @relation(fields: [studyGroupId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([studyGroupId, userId])
  @@index([userId])
}

// A stable pair within a study group (not per-assignment).
model Pair {
  id           String     @id @default(uuid())
  name         String // "Dvojice 1"
  studyGroupId String
  studyGroup   StudyGroup @relation(fields: [studyGroupId], references: [id], onDelete: Cascade)

  members     PairMember[]
  submissions Submission[]

  @@index([studyGroupId])
}

model PairMember {
  id     String @id @default(uuid())
  pairId String
  userId String
  pair   Pair   @relation(fields: [pairId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pairId, userId])
  @@index([userId])
}

// A page inside a subject, switched via the left panel. Pages are plain
// content by default; `template` selects a page template instead ("assignments"
// renders the live assignment list). More templates can be added later.
model SubjectPage {
  id        String   @id @default(uuid())
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  title     String
  slug      String // URL: /subjects/<subject>/p/<slug>
  template  String   @default("content") // content | assignments
  content   String   @default("") // simple markdown-like text for content pages
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files SubjectFile[]

  @@unique([subjectId, slug])
  @@index([subjectId])
}

// A downloadable file attached to a subject page (presentations, manuals, schemas…).
model SubjectFile {
  id          String      @id @default(uuid())
  pageId      String
  page        SubjectPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  label       String // human-readable: "Prezentace – Miniserver"
  fileName    String // original file name on disk
  fileKey     String // stored path: course_files/...
  fileSize    Int // bytes
  mimeType    String      @default("application/octet-stream")
  category    String      @default("material") // material | manual | schema | template | presentation
  description String      @default("")
  order       Int         @default(0)
  isPublished Boolean     @default(true) // draft/published for materials (PRD §5A)

  @@index([pageId])
}

model Enrollment {
  id        String  @id @default(uuid())
  userId    String
  subjectId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId]) // a student can't be enrolled twice
  @@index([subjectId])
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String
  dueDate     DateTime
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  targetType  String   @default("INDIVIDUAL") // INDIVIDUAL | PAIR | GROUP — who submits
  isPublished Boolean  @default(false) // teacher publishes ("zadá") the assignment

  // Optional required consent before the student may submit (PRD §5B).
  requiresConsent Boolean @default(false)
  consentText     String  @default("")

  createdAt DateTime @default(now())

  submissions Submission[]
  grades      Grade[]
  consents    AssignmentConsent[]

  @@index([subjectId])
}

// A submitted file version. The "unit" that owns the version depends on the
// assignment's targetType: a student (INDIVIDUAL), a pair (PAIR) or a study
// group (GROUP). unitKey ("u:<id>" | "p:<id>" | "g:<id>") makes versioning
// unique per unit; the nullable FKs allow relational queries.
model Submission {
  id           String      @id @default(uuid())
  assignmentId String
  assignment   Assignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  version      Int // incremented per unit
  unitKey      String
  userId       String?
  user         User?       @relation("IndividualUnit", fields: [userId], references: [id], onDelete: Cascade)
  pairId       String?
  pair         Pair?       @relation(fields: [pairId], references: [id], onDelete: Cascade)
  studyGroupId String?
  studyGroup   StudyGroup? @relation(fields: [studyGroupId], references: [id], onDelete: Cascade)

  fileName     String // original file name
  fileKey      String // stored file path/key on disk (uploads/...)
  fileSize     Int // bytes
  mimeType     String   @default("application/octet-stream")
  note         String?
  uploadedById String
  uploadedBy   User     @relation("Uploader", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@unique([assignmentId, unitKey, version]) // no two "v2" in the same unit
  @@index([assignmentId])
  @@index([unitKey])
}

model Grade {
  id           String     @id @default(uuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  value        String? // "1", "1-", "2", …
  note         String? // Slovní zpětná vazba (Feedback)
  locked       Boolean    @default(false)
  extension    DateTime?  // Prodloužený termín odevzdání
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([assignmentId, userId])
  @@index([userId])
}

model Test {
  id          String        @id @default(uuid())
  subjectId   String
  subject     Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  title       String
  description String        @default("")
  isPublished Boolean       @default(false)
  timeLimit   Int?          // Limit v minutách, null = bez limitu
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  questions   Question[]
  attempts    TestAttempt[]

  @@index([subjectId])
}

model Question {
  id      String           @id @default(uuid())
  testId  String
  test    Test             @relation(fields: [testId], references: [id], onDelete: Cascade)
  text    String
  type    String           // "SINGLE" | "MULTIPLE" | "TEXT"
  points  Int              @default(1)
  order   Int              @default(0)
  options QuestionOption[]
  answers Answer[]

  @@index([testId])
}

model QuestionOption {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)
  answers    Answer[]

  @@index([questionId])
}

model TestAttempt {
  id          String    @id @default(uuid())
  testId      String
  test        Test      @relation(fields: [testId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt   DateTime  @default(now())
  submittedAt DateTime? // null = rozpracovaný / spuštěný
  score       Float?    // Celkový získaný počet bodů
  feedback    String?   // Slovní komentář učitele k pokusu
  answers     Answer[]

  @@index([testId])
  @@index([userId])
}

model Answer {
  id              String         @id @default(uuid())
  attemptId       String
  attempt         TestAttempt    @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId      String
  question        Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text            String?        // Pro textové otázky
  selectedOptions QuestionOption[] // Implicitní many-to-many relace
  points          Float?         // Udělené body (automaticky nebo ručně učitelem)
  feedback        String?        // Komentář učitele k dané odpovědi

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

model ClassNotification {
  id        String   @id @default(uuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  title     String
  body      String   @default("")
  authorId  String
  author    User     @relation("NotificationAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([classId])
  @@index([authorId])
}
